# ───────────────────────────────────────────────────────────────────────
# Helmsman — combined environment template
# Copy to .env and fill in real values.  NEVER commit .env.
#   cp .env.example .env
#
# This root file covers (1) the wiring that makes NEXUS sit underneath ECC
# and (2) the most common NEXUS provider keys.  ECC's full variable list
# lives in  ecc/.env.example  — both are honoured.
# ───────────────────────────────────────────────────────────────────────

# ─── Wiring: route Claude Code (and ECC-driven agents) through NEXUS ────
# After `helmsman start`, point the Anthropic SDK / Claude Code at NEXUS:
ANTHROPIC_BASE_URL=http://localhost:3000
ANTHROPIC_API_KEY=nexus-local
# NEXUS needs your real Anthropic key to reach Anthropic for premium calls.
# Add it to NEXUS with:  helmsman add anthropic sk-ant-...
# (or export your real key in the shell that runs `nexus start`).

# ─── NEXUS providers (add the ones you use) ─────────────────────────────
# Register with:  helmsman add <provider> <key>
# These are read by `nexus add` / config; see nexus/README.md for the full list.
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
# Local models (no key): Ollama at http://localhost:11434

# ─── ECC essentials (full list in ecc/.env.example) ─────────────────────
GITHUB_TOKEN=
GITHUB_USER="your-github-username"
DEFAULT_BASE_BRANCH="main"
# CLAUDE_CODE_PACKAGE_MANAGER=npm   # npm | pnpm | yarn | bun
# ECC_AGENT_DATA_HOME=$HOME/.claude # multi-harness isolation root
