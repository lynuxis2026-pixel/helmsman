# ── Helmsman monorepo — root ignores ──────────────────────────────────
# Each subproject keeps its own .gitignore (ecc/.gitignore, nexus/.gitignore);
# this file covers root-level and cross-cutting artifacts.

# Secrets / local env
.env
.env.local
*.local

# Node (ecc/ + integration/)
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Go / NEXUS build outputs (scoped — do NOT ignore integration/bin)
nexus/bin/
*.exe
*.test
*.out

# Single-binary build: the operator core is staged here at build time, baked
# into the binary via go:embed, then cleaned away. Only the placeholder is kept.
nexus/internal/operatorfs/data/*
!nexus/internal/operatorfs/data/.gitkeep

# NEXUS local state (SQLite DB, logs)
*.db
*.db-shm
*.db-wal
.nexus/

# Web dashboard (nexus/web)
nexus/web/dist/
nexus/web/node_modules/

# Python (ecc dashboard)
__pycache__/
*.py[cod]
.venv/
venv/

# Rust (ecc/ecc2)
ecc/ecc2/target/

# Editors / OS
.DS_Store
Thumbs.db
*.swp
.idea/
